{"chunk":19,"numChunks":32,"fileHash":"M3OJhuYjvkp4WplCeFFDZIwas539kUb4rlG3UpE4tFw=","filePath":"public/index.html","content":"<!DOCTYPE html>\n<html lang=\"en\" class=\"h-full\">\n<body class=\"flex flex-col h-screen overflow-hidden\">\n    <main class=\"flex-grow flex min-h-0 relative\">\n        <div class=\"flex-grow relative overflow-hidden bg-white\">\n            <div id=\"graph-container\"></div>\n            <!-- ── Node Search Overlay ──────────────────────────────── -->\n            <div id=\"graphSearchBox\"\n                 style=\"position:absolute;top:12px;left:12px;z-index:50;\n                        width:240px;pointer-events:auto\">\n                <div style=\"display:flex;gap:4px\">\n                    <input id=\"graphSearchInput\"\n                        type=\"text\"\n                        placeholder=\"Search node address…\"\n                        oninput=\"window.graphSearch(this.value)\"\n                        onkeydown=\"if(event.key==='Escape'){window.graphSearchClear();this.blur()}\"\n                        style=\"flex:1;background:rgba(15,23,42,0.92);border:1px solid #334155;\n                               border-radius:7px;padding:7px 10px;font-size:10px;font-family:monospace;\n                               color:#67e8f9;outline:none;backdrop-filter:blur(6px);\n                               transition:border-color .15s\"\n                        onfocus=\"this.style.borderColor='#06b6d4'\"\n                        onblur=\"this.style.borderColor='#334155'\">\n                    <button onclick=\"window.graphSearchClear()\"\n                        title=\"Clear search\"\n                        style=\"padding:6px 9px;border-radius:7px;border:1px solid #334155;\n                               background:rgba(15,23,42,0.92);color:#64748b;font-size:12px;\n                               cursor:pointer;backdrop-filter:blur(6px)\">✕</button>\n                </div>\n                <div id=\"graphSearchResults\"\n                     style=\"margin-top:4px;max-height:220px;"}