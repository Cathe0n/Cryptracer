{"chunk":30,"numChunks":32,"fileHash":"M3OJhuYjvkp4WplCeFFDZIwas539kUb4rlG3UpE4tFw=","filePath":"public/index.html","content":"<!DOCTYPE html>\n<html lang=\"en\" class=\"h-full\">\n<body class=\"flex flex-col h-screen overflow-hidden\">\n    <!-- Application entry point; module imports load graph, UI, and utilities -->\n    <script type=\"module\" src=\"main.js\"></script>\n    <!-- ── Focus / Cinema mode ──────────────────────────────────────── -->\n    <button id=\"focusModeBtn\"\n        onclick=\"toggleFocusMode()\"\n        title=\"Hide UI — focus on the graph (press F or Esc to toggle)\"\n        style=\"display:flex;align-items:center;gap:6px;\n               padding:8px 14px;border-radius:8px;border:1px solid #334155;\n               background:rgba(15,23,42,0.85);color:#94a3b8;\n               font-size:11px;font-weight:700;letter-spacing:0.06em;\n               backdrop-filter:blur(6px);cursor:pointer;\n               text-transform:uppercase;transition:all .2s\">\n        ⛶ <span id=\"focusModeLabel\">Focus</span>\n    </button>"}