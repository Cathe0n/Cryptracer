{"chunk":8,"numChunks":16,"fileHash":"jnbSmfQ5lFjfwnSfPWEmG2NK39CSO1wP2NnuTkbD5cY=","filePath":"public/setup.html","content":"<!DOCTYPE html>\n<html lang=\"en\" class=\"h-full\">\n<body class=\"flex items-center justify-center min-h-screen p-4 bg-white\">\n    <div class=\"w-full max-w-2xl\">\n        <div class=\"bg-white border border-slate-200 rounded-xl p-8 shadow-lg\">\n            <form id=\"configForm\" class=\"space-y-6\">\n                <div class=\"border border-slate-200 rounded-lg p-4 bg-slate-50\">\n                    <h3 class=\"text-sm font-bold text-cyan-600 mb-4 uppercase tracking-wider\">Bitquery API (Optional)</h3>\n                    \n                    <div>\n                        <label class=\"block text-xs text-slate-500 mb-2 font-bold uppercase\">API Key</label>\n                        <input type=\"text\" id=\"bitquery_key\" name=\"bitquery_key\" \n                               placeholder=\"BQY...\"\n                               class=\"w-full bg-white border border-slate-300 rounded px-4 py-2 text-sm font-mono focus:border-cyan-500 outline-none text-slate-900 placeholder-slate-400\">\n                        <p class=\"text-xs text-slate-400 mt-1\">\n                            Enables inflow/outflow graph enrichment. Get your key at \n                            <a href=\"https://graphql.bitquery.io\" target=\"_blank\" class=\"text-cyan-500 hover:underline\">graphql.bitquery.io</a>\n                        </p>\n                    </div>\n                </div>\n                <!-- Status Messages -->\n                <div id=\"statusMessage\" class=\"hidden rounded-lg p-4 text-sm\"></div>\n                <!-- Action Buttons -->"}