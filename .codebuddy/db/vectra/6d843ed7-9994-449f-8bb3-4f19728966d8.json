{"chunk":12,"numChunks":16,"fileHash":"jnbSmfQ5lFjfwnSfPWEmG2NK39CSO1wP2NnuTkbD5cY=","filePath":"public/setup.html","content":"<!DOCTYPE html>\n<html lang=\"en\" class=\"h-full\">\n<body class=\"flex items-center justify-center min-h-screen p-4 bg-white\">\n    <div class=\"w-full max-w-2xl\">\n        <div class=\"bg-white border border-slate-200 rounded-xl p-8 shadow-lg\">\n            <div class=\"mt-8 border border-amber-200 rounded-xl p-6 bg-amber-50\">\n                <input type=\"file\" id=\"sessionFileInput\" accept=\".ctk,.json\" class=\"hidden\" onchange=\"handleSessionFile(this.files[0])\">\n\n                <div id=\"sessionPreview\" class=\"hidden mt-4 p-4 rounded-lg bg-white border border-amber-200 space-y-2 text-xs font-mono\">\n                    <div class=\"font-bold text-amber-700 mb-1\">📋 Session Preview</div>\n                    <div class=\"text-slate-500\">Target: <span id=\"prevTarget\" class=\"text-slate-800\"></span></div>\n                    <div class=\"text-slate-500\">Saved:  <span id=\"prevDate\" class=\"text-slate-800\"></span></div>\n                    <div class=\"text-slate-500\">Nodes:  <span id=\"prevNodes\" class=\"text-slate-800\"></span></div>\n                    <div class=\"text-slate-500\">Expanded: <span id=\"prevExpanded\" class=\"text-slate-800\"></span></div>\n                    <div class=\"text-slate-500\">Annotations: <span id=\"prevAnnot\" class=\"text-slate-800\"></span></div>\n                    <button id=\"loadSessionBtn\" onclick=\"launchSession()\"\n                        class=\"mt-3 w-full bg-amber-500 hover:bg-amber-400 text-white font-bold py-2.5 rounded uppercase tracking-widest text-xs transition"}